# SQLite database for local development (Prisma schema lives in ./prisma)
DATABASE_URL="file:./dev.db"

# Secret pepper used when hashing session tokens before DB storage.
# Use a long random value in real environments.
SESSION_TOKEN_PEPPER="replace-with-a-long-random-secret"

# Session TTL in seconds (default in code is 1209600 = 14 days)
SESSION_TTL_SECONDS="1209600"

# Session cookie name. Keep __Host- prefix when served over HTTPS.
SESSION_COOKIE_NAME="__Host-cyclop-eddy-session"
